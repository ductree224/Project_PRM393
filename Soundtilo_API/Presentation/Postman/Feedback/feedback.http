@adminToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..K94xgwBwhzKfX7Kq_UHy5SpF2V1rOj8atm5g9wJjY94
@feedbackId = 6983da97-4f1f-4c46-94bf-c3178511ecc5

##################################################
### 1. USER CREATE FEEDBACK
##################################################
POST {{Host}}/api/feedbacks
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "category": "bug",
  "priority": "high",
  "title": "Crash khi play nhạc",
  "content": "App crash khi play bài số 70",
  "deviceInfo": "iPhone 174",
  "platform": "ios",
  "appVersion": "1.0.2",
  "attachmentUrl": "https://example.com/image.png"
}

##################################################
### 1. USER CREATE FEEDBACK - (2)
##################################################
POST {{Host}}/api/feedbacks
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "category": "bug",
  "priority": "high",
  "title": "Crash khi play nhạc",
  "content": "App crash khi play bài số 821",
  "deviceInfo": "iPhone 1221",
  "platform": "ios",
  "appVersion": "1.0.2",
  "attachmentUrl": "https://example.com/image.png"
}

##################################################
### 2. USER VIEW OWN FEEDBACK
##################################################
GET {{Host}}/api/feedbacks/me
Authorization: Bearer {{userToken}}

##################################################
### 3. ADMIN GET ALL (FILTER + PAGINATION)
##################################################
GET {{Host}}/api/feedbacks?status=pending&category=bug&page=1&pageSize=10
Authorization: Bearer {{adminToken}}

##################################################
### 4. ADMIN HANDLE FEEDBACK
##################################################
PUT {{Host}}/api/feedbacks/{{feedbackId}}/handle
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "reply": "Đã fix bug này rồi nhé",
  "status": "resolved"
}

##################################################
### 5. USER CHECK AGAIN (SEE REPLY)
##################################################
GET {{Host}}/api/feedbacks/me
Authorization: Bearer {{userToken}}

##################################################
### 6. ANALYTICS DASHBOARD
##################################################
GET {{Host}}/api/feedbacks/analytics?days=7
Authorization: Bearer {{adminToken}}

##################################################
### 7. ANALYTICS 30 DAYS
##################################################
GET {{Host}}/api/feedbacks/analytics?days=30
Authorization: Bearer {{adminToken}}

